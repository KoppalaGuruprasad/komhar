--monthly revenue

select 
date_trunc('month',order_date) as order_month,
sum(amount) as total_revenue
from fact_orders
group by order_month;

select * from fact_orders;

--running total order amount per customer order by date

select 
customer_id,
order_date,
amount,
sum(amount) over(partition by customer_id order by order_date) as running_total
from fact_orders;

--Detect duplicate ORDER_ID values in FACT_ORDERS
select order_id,
count(*) as duplicate_count
from fact_orders
group by order_id
having count(*) >1;

-- difference between union and union all
select 
customer_id from dim_customer
union
select customer_id from fact_orders;

select 
customer_id from dim_customer
union all
select customer_id from fact_orders;

--previous order amount per customer using LAG

select 
customer_id,
order_date,
amount,
lag(amount) over(partition by customer_id order by order_date) as previous_amount
from fact_orders;


--running order_amount + previous order amount

select *,
lag(amount) over(partition by customer_id order by order_date) as previous_amount
from (
select 
customer_id,
order_date,
amount,
sum(amount) over(partition by customer_id order by order_date) as running_total
from fact_orders
);

--next order amount per customer using lead

select *,
lead(amount) over(partition by customer_id order by order_date) as next_amount_order
from (
select 
customer_id,
order_date,
amount,
sum(amount) over(partition by customer_id order by order_date) as running_total
from fact_orders
);

-- orders where amount is greaterthan avg amount of the customer's

with cte as
(
select 
customer_id,
order_id,
order_date,
amount,
avg(amount) over (partition by customer_id) as avg_amount
from fact_orders
)
select * from cte
where amount > avg_amount;


-- highest order amount per customer
select
d.city,
f.amount,
f.order_id from dim_customer d
join fact_orders f
on d.customer_id = f.customer_id
qualify row_number() over (partition by d.city order by f.amount desc) = 1;

select * from dim_customer;


 --number of days between consecutive orders for each customer

select
customer_id,
order_date,
order_id,
lag(order_date) over (partition by customer_id order by order_date) as previous_order_date,
datediff(day,lag(order_date) over (partition by customer_id order by order_date),order_date) as days_between_orders
from fact_orders;

--Count number of orders by STATUS.

select status,
count(*) as order_count
from fact_orders
group by status;

--Categorize customers into Platinum, Gold, Silver based on revenue.

select 
d.customer_name,
d.customer_id,
sum(amount) as revenue,
case
when revenue > 3100 then 'platinum'
when revenue between 1500 and 3200 then 'gold'
else 'silver'
end as category
from fact_orders f
join dim_customer d
on d.customer_id = f.customer_id
group by d.customer_id,customer_name;

-- Retrieve first and last order date per customer.

select 
d.customer_id,
d.customer_name,
min(order_date) as first_order_date,
max(order_date) as last_order_date,
from fact_orders
join dim_customer d
group by d.customer_id,d.customer_name;

-- highest order placed each day

select 
order_date,
order_id,
amount
from fact_orders
qualify row_number() over(
partition by order_date order by order_id desc
)=1;

-- List customers who placed more than 5 orders.

select
d.customer_id,
d.customer_name,
count(f.order_id) as total_orders
from dim_customer d
join fact_orders f
on d.customer_id = f.customer_id
group by d.customer_id, d.customer_name
having count(f.order_id) > 5;

--Retrieve orders placed in the last 7 days.
select
customer_id,
order_id,
order_date,
amount,
from fact_orders
where order_date >= current_date- 7 and order_date <=current_date ;
