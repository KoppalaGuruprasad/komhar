-- top 3 customers based on total order amount.

select
d.city,
d.customer_name,
sum(amount) as total_amount,
from dim_customer d
join fact_orders f
on d.customer_id = f.customer_id
group by d.city, d.customer_name
qualify row_number() over
(
partition by d.city order by total_amount desc
)<= 3;

--latest order placed by each customer.

select 
customer_id,
order_id,
order_date
from fact_orders
qualify row_number() over 
(
partition by customer_id order by order_date desc
)=1
order by customer_id;
