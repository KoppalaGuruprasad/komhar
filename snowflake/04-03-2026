--/ this query finds the latest order per customer
SELECT *
FROM
(
SELECT 
CUSTOMER_ID,
ORDER_ID,
ORDER_DATE,
AMOUNT,
ROW_NUMBER() OVER(
PARTITION BY CUSTOMER_ID
ORDER BY ORDER_DATE DESC
) AS RN
FROM FACT_ORDERS
)
WHERE RN = 1;
