--/ cte based aggregation

MERGE INTO DIM_CUSTOMER d
USING (
SELECT 
customer_id,
CASE
    WHEN SUM(amount) > 50000 THEN 'PLATINUM'
    WHEN SUM(amount) BETWEEN 20000 AND 50000 THEN 'GOLD'
    ELSE 'SILVER'
END AS customer_type
FROM FACT_ORDERS
GROUP BY customer_id
) s
ON d.customer_id = s.customer_id
WHEN MATCHED 
AND d.customer_type <> s.customer_type
THEN UPDATE SET
d.customer_type = s.customer_type,
d.updated_date = CURRENT_TIMESTAMP
WHEN NOT MATCHED
THEN INSERT
(customer_id, customer_type, updated_date)
VALUES
(s.customer_id, s.customer_type, CURRENT_TIMESTAMP);

SELECT * FROM DIM_CUSTOMER;

--2.b.customer perfomance report /
WITH cte AS (
SELECT 
customer_id,
SUM(amount) AS total_revenue
FROM fact_orders
GROUP BY customer_id
),
latest_order AS (
SELECT 
customer_id,
amount AS latest_order_amount,
ROW_NUMBER() OVER (
PARTITION BY customer_id ORDER BY order_date DESC
) AS rn
FROM fact_orders
)
SELECT 
d.customer_name,
d.city,
c.total_revenue,
CASE
    WHEN c.total_revenue > 50000 THEN 'PLATINUM'
    WHEN c.total_revenue BETWEEN 20000 AND 50000 THEN 'GOLD'
    ELSE 'SILVER'
END AS revenue_category,
l.latest_order_amount,
RANK() OVER (
PARTITION BY d.city 
ORDER BY c.total_revenue DESC
) AS customer_rank
FROM dim_customer d
JOIN cte c
ON d.customer_id = c.customer_id
LEFT JOIN latest_order l
ON d.customer_id = l.customer_id
AND l.rn = 1;




